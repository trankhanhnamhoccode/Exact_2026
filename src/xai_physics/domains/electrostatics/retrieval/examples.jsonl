{"id":"elec_ld022_midpoint_force_opposite_charges","domain":"electrostatics","tags":["net_force","midpoint","pairwise_distances","coulomb"],"problem":"Two charges q1 = +2 μC and q2 = -2 μC are placed 10 cm apart. A charge q3 = +1 μC is placed at the midpoint of the line segment connecting q1 and q2. Calculate the net force on q3.","schema":{"domain":"electrostatics","points":[{"id":"A"},{"id":"B"},{"id":"M"}],"geometry":[{"type":"PairwiseDistances","points":["A","B"],"distances":[{"between":["A","B"],"value":10,"unit":"cm"}]},{"type":"Midpoint","point":"M","between":["A","B"]}],"charges":[{"id":"q1","charge":{"value":2,"unit":"uC"},"at":"A"},{"id":"q2","charge":{"value":-2,"unit":"uC"},"at":"B"},{"id":"q3","charge":{"value":1,"unit":"uC"},"at":"M"}],"queries":[{"type":"net_force","target":"q3","output":"magnitude","unit":"N"}]}}
{"id":"elec_ld362_perpendicular_electric_fields_from_sources","domain":"electrostatics","tags":["electric_field","perpendicular_fields","perpendicular_rays"],"problem":"At point M, the electric fields produced by q1 and q2 are perpendicular. q1 = 2 μC is 3 cm from M and q2 = 4 μC is 4 cm from M. Calculate the resultant electric field magnitude at M.","schema":{"domain":"electrostatics","points":[{"id":"M"},{"id":"A"},{"id":"B"}],"geometry":[{"type":"PerpendicularRaysFromPoint","center":"M","points":["A","B"],"distances":[{"value":3,"unit":"cm"},{"value":4,"unit":"cm"}]}],"charges":[{"id":"q1","charge":{"value":2,"unit":"uC"},"at":"A"},{"id":"q2","charge":{"value":4,"unit":"uC"},"at":"B"}],"queries":[{"type":"electric_field","target":"M","output":"magnitude","unit":"V/m"}]}}
{"id":"elec_ld014_inverse_coulomb_equal_charges","domain":"electrostatics","tags":["inverse_coulomb","equal_charges","net_force"],"problem":"Two charges separated by 15 cm exert a force of 4.8 N. Given q1 = q2 = q, find q.","schema":{"domain":"electrostatics","queries":[{"type":"coulomb_equal_charge","force":{"value":4.8,"unit":"N"},"distance":{"value":15,"unit":"cm"},"output":"magnitude","unit":"uC"}]}}
{"id":"elec_ld020_inverse_resultant_angle","domain":"electrostatics","tags":["resultant_vector","inverse_angle","forces_given"],"problem":"Two forces each have magnitude 10 N. Find the angle between them if the resultant force is also 10 N.","schema":{"domain":"electrostatics","vectors":[{"id":"F1","magnitude":{"value":10,"unit":"N"}},{"id":"F2","magnitude":{"value":10,"unit":"N"}}],"queries":[{"type":"resultant_angle","target":"vectors","resultant":{"value":10,"unit":"N"},"output":"magnitude","unit":"degree"}]}}
{"id":"elec_ld021_opposite_sides_target_centered_collinear","domain":"electrostatics","tags":["net_force","collinear","opposite_sides","coulomb"],"problem":"A charge q = -1 μC is attracted by two +1 μC charges on opposite sides of q, at distances 5 cm and 12 cm from q. Calculate the net force on q.","schema":{"domain":"electrostatics","points":[{"id":"A"},{"id":"Q"},{"id":"B"}],"geometry":[{"type":"Collinear","points":["A","Q","B"],"order":["A","Q","B"],"distances":[{"between":["A","Q"],"value":5,"unit":"cm"},{"between":["Q","B"],"value":12,"unit":"cm"}]}],"charges":[{"id":"q","charge":{"value":-1,"unit":"uC"},"at":"Q"},{"id":"q1","charge":{"value":1,"unit":"uC"},"at":"A"},{"id":"q2","charge":{"value":1,"unit":"uC"},"at":"B"}],"queries":[{"type":"net_force","target":"q","output":"magnitude","unit":"N"}]}}
{"id":"elec_ld025_point_on_segment_one_distance","domain":"electrostatics","tags":["net_force","point_on_line","collinear","coulomb"],"problem":"q1 and q2 are at the ends of a 10 cm segment. q3 is on the line connecting them, 4 cm from q1. Calculate the force on q3.","schema":{"domain":"electrostatics","points":[{"id":"A"},{"id":"B"},{"id":"C"}],"geometry":[{"type":"PairwiseDistances","points":["A","B"],"distances":[{"between":["A","B"],"value":10,"unit":"cm"}]},{"type":"PointOnLine","point":"C","start":"A","end":"B","distance_from_start":{"value":4,"unit":"cm"},"direction":"toward_end"}],"charges":[{"id":"q1","charge":{"value":2,"unit":"uC"},"at":"A"},{"id":"q2","charge":{"value":2,"unit":"uC"},"at":"B"},{"id":"q3","charge":{"value":-1,"unit":"uC"},"at":"C"}],"queries":[{"type":"net_force","target":"q3","output":"magnitude","unit":"N"}]}}
{"id":"elec_ld032_pairwise_m_from_a_b","domain":"electrostatics","tags":["net_force","pairwise_distances","collinear","coulomb"],"problem":"Two charges q1 and q2 are separated by 8 cm. q0 is placed at M, 4 cm from A and 12 cm from B. Determine the force on q0.","schema":{"domain":"electrostatics","points":[{"id":"A"},{"id":"B"},{"id":"M"}],"geometry":[{"type":"PairwiseDistances","points":["A","B","M"],"distances":[{"between":["A","B"],"value":8,"unit":"cm"},{"between":["A","M"],"value":4,"unit":"cm"},{"between":["B","M"],"value":12,"unit":"cm"}],"orientation":"above"}],"charges":[{"id":"q1","charge":{"value":1e-07,"unit":"C"},"at":"A"},{"id":"q2","charge":{"value":-1e-07,"unit":"C"},"at":"B"},{"id":"q0","charge":{"value":1e-07,"unit":"C"},"at":"M"}],"queries":[{"type":"net_force","target":"q0","output":"magnitude","unit":"N"}]}}
{"id":"elec_symbolic_perpendicular_bisector_equal_charges","domain":"electrostatics","tags":["symbolic","symbolic_geometry","perpendicular_bisector","equal_charges","electric_field","field_expression"],"problem":"Two charges q1 = q2 = q are placed at A and B with AB = 2a. Point M is on the perpendicular bisector, distance h from AB. Determine the magnitude of the electric field at M.","schema":{"domain":"electrostatics","representation":"symbolic","solver_backend":"symbolic_geometry","tags":["symbolic","symbolic_geometry","perpendicular_bisector","equal_charges"],"points":[{"id":"A","x":"-a","y":"0"},{"id":"B","x":"a","y":"0"},{"id":"M","x":"0","y":"h"}],"charges":[{"id":"q1","charge":"q","at":"A"},{"id":"q2","charge":"q","at":"B"}],"queries":[{"type":"electric_field","target":"M","output":"magnitude","answer_mode":"symbolic_expr","unit":"V/m"}],"constraints":["AB=2a; keep a,h,q symbolic and superpose field vectors."]}}
{"id":"elec_symbolic_square_center_sign_pattern","domain":"electrostatics","tags":["symbolic","symbolic_geometry","square","center","sign_pattern","electric_field"],"problem":"Four charges of magnitude q are placed at the vertices of square ABCD, side a. Positive charges are at A and D, negative charges are at B and C. Determine the electric field at the intersection of diagonals.","schema":{"domain":"electrostatics","representation":"symbolic","solver_backend":"symbolic_geometry","tags":["symbolic","symbolic_geometry","square","center","sign_pattern"],"medium":{"relative_permittivity_symbol":"epsilon"},"points":[{"id":"A","x":"-a/2","y":"a/2"},{"id":"B","x":"a/2","y":"a/2"},{"id":"C","x":"a/2","y":"-a/2"},{"id":"D","x":"-a/2","y":"-a/2"},{"id":"O","x":"0","y":"0"}],"charges":[{"id":"qA","charge":"q","at":"A"},{"id":"qD","charge":"q","at":"D"},{"id":"qB","charge":"-q","at":"B"},{"id":"qC","charge":"-q","at":"C"}],"queries":[{"type":"electric_field","target":"O","output":"magnitude","answer_mode":"symbolic_expr","unit":"V/m"}],"constraints":["Use symbolic square coordinates; do not assume zero unless vector sum cancels."]}}
{"id":"elec_symbolic_midpoint_inverse_sqrt_field","domain":"electrostatics","tags":["symbolic","symbolic_relation","midpoint","inverse_sqrt_field"],"problem":"A charge q is at O. A and B are on the same field line and M is the midpoint of AB. Given field strengths E_A and E_B, determine 1/sqrt(E_M).","schema":{"domain":"electrostatics","representation":"symbolic","solver_backend":"symbolic_relation","tags":["symbolic","symbolic_relation","midpoint","inverse_sqrt_field"],"queries":[{"type":"midpoint_inverse_sqrt_field_relation","left":"1/sqrt(E_M)","left_endpoint_field":"E_A","right_endpoint_field":"E_B","answer_mode":"symbolic_relation","unit":"-"}],"constraints":["For one point charge, 1/sqrt(E) is proportional to distance; midpoint distances average."]}}
{"id":"elec_continuous_ring_axial_field","domain":"electrostatics","tags":["continuous_distribution","ring","axis","electric_field"],"problem":"A thin circular ring of radius R carries total charge Q uniformly. Find the electric field on the axis a distance z from the center.","schema":{"domain":"electrostatics","representation":"numeric","solver_backend":"continuous_distribution","tags":["continuous_distribution","ring","axis"],"distribution":{"type":"ring_axial","charge":{"value":3,"unit":"uC"},"radius":{"value":5,"unit":"cm"},"axis_distance":{"value":2.5,"unit":"cm"}},"queries":[{"type":"electric_field","output":"magnitude","unit":"V/m"}],"constraints":["Use E = kQz/(R^2+z^2)^(3/2); do not replace the ring by a point charge at the center."]}}
{"id":"elec_continuous_parallel_infinite_sheets","domain":"electrostatics","tags":["continuous_distribution","infinite_sheet","surface_charge_density","parallel_sheets"],"problem":"Two wide parallel insulating sheets have surface charge densities sigma and -sigma. Find the field between them.","schema":{"domain":"electrostatics","representation":"numeric","solver_backend":"continuous_distribution","tags":["continuous_distribution","infinite_sheet","opposite"],"distribution":{"type":"parallel_infinite_sheets","surface_charge_density":{"value":8.85e-06,"unit":"C/m^2"},"arrangement":"opposite"},"queries":[{"type":"electric_field","output":"magnitude","unit":"V/m"}],"constraints":["Opposite infinite sheets add between the sheets: E=sigma/eps0. Identical sheets cancel between them."]}}
{"id":"elec_continuous_disk_axial_field","domain":"electrostatics","tags":["continuous_distribution","disk","surface_charge_density","axis"],"problem":"A uniformly charged disk of radius R and surface charge density sigma. Find the axial field at distance z from the center.","schema":{"domain":"electrostatics","representation":"numeric","solver_backend":"continuous_distribution","tags":["continuous_distribution","disk","axis"],"distribution":{"type":"disk_axial","surface_charge_density":{"value":5e-06,"unit":"C/m^2"},"radius":{"value":10,"unit":"cm"},"axis_distance":{"value":5,"unit":"cm"}},"queries":[{"type":"electric_field","output":"magnitude","unit":"V/m"}],"constraints":["Use E_z=sigma/(2 eps0)*(1-z/sqrt(z^2+R^2))."]}}
{"id":"elec_continuous_semicircle_center_field","domain":"electrostatics","tags":["continuous_distribution","semicircle","center","electric_field"],"problem":"A charge Q is uniformly distributed along a semicircle of radius R. Determine the electric field at the center.","schema":{"domain":"electrostatics","representation":"numeric","solver_backend":"continuous_distribution","tags":["continuous_distribution","semicircle","center"],"distribution":{"type":"semicircle_center","charge":{"value":7e-10,"unit":"C"},"radius":{"value":20,"unit":"cm"}},"queries":[{"type":"electric_field","output":"magnitude","unit":"V/m"}],"constraints":["Use E=2kQ/(pi R^2) for a uniformly charged semicircle at the center."]}}
